# ─────────────────────────────────────────────────────────────────────────────
#  Amara Dental — plantilla de PRODUCCIÓN (api.amaradental.mx)
#  Copia este archivo a  .env  y rellena solo los  <VALORES>  entre <>.
#  NUNCA subas el .env real a git (lleva secretos).
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Amara Dental"
APP_ENV=production
APP_KEY=                              # déjalo vacío y corre:  php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=America/Mexico_City
APP_URL=https://api.amaradental.mx

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ── Base de datos (la MySQL que creaste en Plesk) ────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=<TU_BASE_DE_DATOS>
DB_USERNAME=<TU_USUARIO_DB>
DB_PASSWORD=<TU_PASSWORD_DB>

# ── Multi-tenant ─────────────────────────────────────────────────────────────
# Activa la resolución por subdominio:  clinica-x.amaradental.mx → tenant.
TENANCY_CENTRAL_DOMAINS=amaradental.mx

# ── Sanctum / Sesión (login con cookie compartida entre subdominios) ─────────
SANCTUM_STATEFUL_DOMAINS=amaradental.mx,*.amaradental.mx
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.amaradental.mx        # el punto inicial es OBLIGATORIO (cookie para *.amaradental.mx)
SESSION_SECURE_COOKIE=true            # requiere HTTPS (ya tienes SSL comodín)
SESSION_SAME_SITE=lax

# ── CORS (acepta cualquier subdominio de amaradental.mx con credenciales) ────
CORS_ALLOWED_ORIGIN_PATTERNS=#^https://([a-z0-9-]+\.)?amaradental\.mx$#

# ── Cache / Cola / Archivos ──────────────────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
BCRYPT_ROUNDS=12

# ── Correo (SMTP de Plesk) ───────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=<smtp.tu-servidor-plesk>
MAIL_PORT=587
MAIL_USERNAME=<usuario_smtp>
MAIL_PASSWORD=<password_smtp>
MAIL_SCHEME=null                      # 'tls' si el puerto es 465; null para 587/STARTTLS
MAIL_FROM_ADDRESS="no-reply@amaradental.mx"
MAIL_FROM_NAME="Amara Dental"

# ── Stripe / Cashier ─────────────────────────────────────────────────────────
# Empieza en modo TEST (pk_test_/sk_test_). Cambia a live (pk_live_/sk_live_)
# cuando vayas a cobrar de verdad. El webhook lo creas en el panel de Stripe
# apuntando a:  https://api.amaradental.mx/stripe/webhook
STRIPE_KEY=<pk_test_o_pk_live_...>
STRIPE_SECRET=<sk_test_o_sk_live_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>
CASHIER_CURRENCY=mxn
CASHIER_CURRENCY_LOCALE=es_MX

# Price IDs de cada plan (panel de Stripe → Productos → precio → "price_...").
# OJO: son price_... NO prod_...
STRIPE_PRICE_ESENCIAL=<price_...>
STRIPE_PRICE_CRECIMIENTO=<price_...>
STRIPE_PRICE_PREMIUM=<price_...>

VITE_APP_NAME="${APP_NAME}"
