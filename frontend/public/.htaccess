# SPA fallback: cualquier ruta que no sea un archivo real se sirve con index.html
# (si no, recargar en /configuracion, /agenda, etc. daría 404).
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Si el archivo o carpeta existe, sírvelo tal cual (assets, favicon, etc.).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás → index.html (lo resuelve el router de React).
    RewriteRule ^ index.html [L]
</IfModule>

# Cache largo para assets con hash; el index.html nunca se cachea.
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|svg|woff2?|png|jpg|jpeg|gif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
